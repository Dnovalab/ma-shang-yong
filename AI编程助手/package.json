{
  "name": "ai-code-assistant",
  "version": "1.1.0",
  "description": "AI编程助手 —— 打开就能用的国产AI编程工具",
  "main": "main.js",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "start": "electron .",
    "build-mac": "npm run setup && electron-builder --mac --config build.config.json",
    "build-win": "npm run setup && electron-builder --win --config build.config.json",
    "build-linux": "npm run setup && electron-builder --linux --config build.config.json"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
